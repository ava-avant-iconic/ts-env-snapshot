{
  "name": "ts-env-snapshot",
  "version": "0.1.0",
  "description": "Capture, compare, and diff environment variable snapshots across deploys. Detect added/removed/changed env vars and generate human-readable drift reports for CI/CD pipelines.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "env",
    "environment",
    "snapshot",
    "diff",
    "drift",
    "deploy",
    "ci-cd",
    "typescript"
  ],
  "author": "AVA-ANT-ICONIC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ava-avant-iconic/ts-env-snapshot"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
